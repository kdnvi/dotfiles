vim9script

set nocompatible regexpengine=2 noswapfile nobackup
set ignorecase smartcase hlsearch incsearch updatetime=512
set showmatch ruler title visualbell cursorline autoread
set shiftwidth=4 tabstop=4 softtabstop=4 expandtab shiftround
set wildoptions=pum,tagfile,fuzzy wildcharm=<C-z>
set autocomplete completeopt+=fuzzy sessionoptions-=options
set autoindent smartindent number
set list listchars=tab:>\ ,trail:-,nbsp:+
&showbreak = '+++ '
filetype plugin on
filetype indent on
syntax enable

nnoremap <Space>f :find **
nnoremap <Space>F :find **<C-r><C-w><C-z>
nnoremap <Space>g :vimgrep //j **<S-Left><Left><Left><Left>
vnoremap <Space>g "0y:vimgrep /<C-r>0/j **<S-Left><Left><Left><Left>
nnoremap <Space>G :vimgrep /<C-r><C-w>/j **<CR>

# terminal emulators historically map C-Space to the null byte (\0, ASCII 0)
# which VIM represents as <NUL>
nnoremap <NUL> :ls t<CR>:buffer 
nnoremap - :edit %:.:h<C-z><C-z>

# redraw + clear search highlight
nnoremap <C-l> <Cmd>nohlsearch<Bar>diffupdate<Bar>redraw!<CR>
g:netrw_dirhistmax = 0

# clipboard
# all motions after [<Space>y] work the same as normal [y]
nnoremap <Space>y "+y
vnoremap <Space>y "+y
nnoremap <Space>p "+p
vnoremap <Space>p "+p
nnoremap <Space>P "+P

# command mode navigation
cnoremap <C-a> <Home>
cnoremap <C-e> <End>
cnoremap <C-b> <Left>
cnoremap <C-f> <Right>

# terminal window navigation
tnoremap <C-w><C-h> <C-w>h
tnoremap <C-w><C-j> <C-w>j
tnoremap <C-w><C-k> <C-w>k
tnoremap <C-w><C-l> <C-w>l

autocmd BufNewFile,BufRead *.log* setfiletype messages
autocmd BufNewFile,BufRead *.psql setfiletype sql
autocmd BufNewFile,BufRead *.mdc  setfiletype markdown
autocmd FileType help,qf,messages nnoremap <buffer> q <Cmd>bdelete<CR>
autocmd TerminalWinOpen * nnoremap <buffer> q <Cmd>bdelete!<CR>
autocmd QuickFixCmdPost [^l]* cwindow

# local-specific config
&undodir = $'{$XDG_STATE_HOME}/vim/undo'
if !isdirectory(&undodir) | mkdir(&undodir, 'p') | endif
set undofile laststatus=2 background=dark
colorscheme retrobox

# extend find/vimgrep with ripgrep
if executable('rg')
  def g:RgFindFunc(cmdarg: string, _is_completion: bool): list<string>
    var result = systemlist('rg --files --hidden')
    if v:shell_error != 0
      return []
    endif
    return empty(cmdarg) ? result : matchfuzzy(result, cmdarg)
  enddef
  set findfunc=g:RgFindFunc
  nnoremap <Space>f :find 
  nnoremap <Space>F :find <C-r><C-w><C-z>
  # add [--hidden --no-ignore] for wildcard
  set grepprg=rg\ --vimgrep\ $*
  set grepformat=%f:%l:%c:%m
  nnoremap <Space>g :grep! ''<Left>
  vnoremap <Space>g "0y:grep! '<C-r>0'<Left>
  nnoremap <Space>G :grep! '<C-r><C-w>'<CR>
endif

# sessionize
source <sfile>:h/utils/session.vim
command! Blame {
  const start = line('.')
  const finish = start + 10
  execute $'!git blame -L {start},{finish} %'
}

# enable optional packages
packadd comment
packadd hlyank
g:hlyank_duration = 128

# keep things simple here, only essentials
# plugins are managed as git submodules under vim/pack/plugins/opt/
source <sfile>:h/utils/lsp.vim

defcompile
