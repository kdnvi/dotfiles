#!/usr/bin/env bash
pattern=${1:-}
if [[ -z $pattern ]]; then
    echo "usage: $(basename "$0") <pattern>"
    tree -L 3 -d "$HOME/repos" "$HOME/personal"
    exit 1
fi # ensure pattern is specified

matched=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -iF "$pattern" | head -1)
if [[ -n $matched ]]; then
    exec tmux switch-client -t "$matched"
fi # try matching session name first

matched=$(tmux list-windows -a -F '#{session_name}:#{window_index}:#{window_name}' 2>/dev/null | grep -iF "$pattern" | head -1)
if [[ -n $matched ]]; then
    session_name=${matched%%:*}
    window_index=${matched#*:}; window_index=${window_index%%:*}
    exec tmux switch-client -t "${session_name}:${window_index}"
fi # fallback to matching window name

dir=$(find "$HOME/repos" "$HOME/personal" -maxdepth 3 -type d -iname "${pattern}*" 2>/dev/null | head -1)
if [[ -z $dir ]]; then
    tmux display-message "no project found matching '$pattern'"
    exit 0
fi # no session or window matched - try finding a project directory

name=$(basename "$dir")
if ! tmux has-session -t "$name" 2>/dev/null; then
    tmux new-session -s "$name" -d -c "$dir"
fi # create session if it doesn't exist

exec tmux switch-client -t "$name"
# vim: ft=bash
