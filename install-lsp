#!/usr/bin/env bash
set -euo pipefail

readonly XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"

install_jdtls() {
    local jdtls_dir="$XDG_DATA_HOME/eclipse.jdt.ls"
    if [[ ! -d $jdtls_dir ]]; then
        git clone https://github.com/eclipse-jdtls/eclipse.jdt.ls "$jdtls_dir"
    else
        git -C "$jdtls_dir" fetch --tags
    fi

    local latest_tag
    latest_tag=$(git -C "$jdtls_dir" tag --sort=-version:refname | head -1)
    git -C "$jdtls_dir" checkout "$latest_tag"

    "$jdtls_dir/mvnw" -f "$jdtls_dir/pom.xml" clean verify -DskipTests=true
}

if [[ $(uname -s) == Darwin ]]; then
    brew install pipx node
else
    sudo apt-get update
    sudo apt-get install -y clangd pipx nodejs npm
fi

pipx install pyright
npm install -g typescript-language-server

install_jdtls
