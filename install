#!/bin/sh
set -eu

DOTFILES_DIR="$HOME/dotfiles"
REPO_URL="https://github.com/kdnvi/dotfiles.git"

echo '> installing essential packages'
case $(uname -s) in
    Linux)
        sudo dnf update -y && sudo dnf install -y git bash tmux neovim ripgrep tree ncdu htop jq pandoc
        ;;
    Darwin)
        xcode-select -p >/dev/null 2>&1 || { echo '> installing command line tools for xcode'; xcode-select --install; }
        command -v brew >/dev/null 2>&1 || {
            echo '> installing homebrew'
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
            eval "$(/opt/homebrew/bin/brew shellenv)"
        }
        brew update && brew install git bash bash-completion@2 tmux neovim ripgrep tree ncdu htop jq pandoc
        ;;
    *)  echo '! unsupported os: only linux and mac' >&2; exit 1 ;;
esac

echo '> creating essential dirs'
mkdir -p ~/.config ~/work ~/lab ~/.claude

echo '> cloning dotfiles'
[ -d "$DOTFILES_DIR/.git" ] || git clone "$REPO_URL" "$DOTFILES_DIR"

echo '> linking dotfiles'
ln -sfn "$DOTFILES_DIR/nvim" ~/.config/nvim
ln -sfn "$DOTFILES_DIR/.tmux.conf" ~/.tmux.conf
ln -sfn "$DOTFILES_DIR/.gitignore" ~/.gitignore
ln -sfn "$DOTFILES_DIR/.psqlrc" ~/.psqlrc
ln -sfn "$DOTFILES_DIR/.bashrc" ~/.bashrc
[ -f ~/.bash_profile ] || echo '[ -r ~/.bashrc ] && . ~/.bashrc' >> ~/.bash_profile

echo '> linking bin scripts'
mkdir -p ~/.local/bin
for f in $(pwd)/localbin/*; do
    ln -sfn "$f" "$HOME/.local/bin/$(basename "$f")"
done

echo '> configuring claude agent'
ln -sfn "$DOTFILES_DIR/claude/CLAUDE.md" ~/.claude/CLAUDE.md
ln -sfn "$DOTFILES_DIR/claude/skills" ~/.claude/skills
ln -sfn "$DOTFILES_DIR/claude/agents" ~/.claude/agents

echo '> downloading git-completion.bash and git-prompt.sh'
curl -fsSL https://raw.githubusercontent.com/git/git/refs/heads/master/contrib/completion/git-completion.bash -o ~/.git-completion.bash
curl -fsSL https://raw.githubusercontent.com/git/git/refs/heads/master/contrib/completion/git-prompt.sh -o ~/.git-prompt.sh

echo '> configuring git'
git config --global core.excludesFile ~/.gitignore
git config --global push.autoSetupRemote true
git config --global pull.rebase true
git config --global diff.tool nvimdiff
git config --global merge.tool nvimdiff
git config --global mergetool.keepBackup false

[ "${SHELL##*/}" = bash ] && { echo '* default shell is already bash'; exit 0; }
bash_path=$(command -v bash || true)
[ -n "$bash_path" ] || { echo '! bash not found in path' >&2; exit 1; }

echo '> changing default shell to bash'
grep -qxF "$bash_path" /etc/shells || echo "$bash_path" | sudo tee -a /etc/shells

chsh -s "$bash_path"
echo '* please log out and log back in for shell change to take effect'
# vim: ft=sh
