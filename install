#!/bin/sh
set -eu

DOTFILES_DIR="$HOME/dotfiles"
REPO_URL="https://github.com/kdnvi/dotfiles.git"

echo '> installing essential packages'
case $(uname -s) in
    Linux)
        sudo dnf update -y && sudo dnf install -y git fish tmux neovim ripgrep tree ncdu htop jq google-noto-sans-mono-fonts
        ;;
    Darwin)
        xcode-select -p >/dev/null 2>&1 || { echo '> installing command line tools for xcode'; xcode-select --install; }
        command -v brew >/dev/null 2>&1 || {
            echo '> installing homebrew'
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
            eval "$(/opt/homebrew/bin/brew shellenv)"
        }
        brew update && brew install git fish tmux neovim ripgrep tree ncdu htop jq font-noto-sans-mono
        ;;
    *)  echo '! unsupported os: only linux and mac' >&2; exit 1 ;;
esac

echo '> creating essential dirs'
mkdir -p ~/.config ~/work ~/lab ~/side

echo '> cloning/updating dotfiles'
if [ -d "$DOTFILES_DIR/.git" ]; then
    git -C "$DOTFILES_DIR" pull
else
    git clone "$REPO_URL" "$DOTFILES_DIR"
fi
cd "$DOTFILES_DIR"

echo '> linking dotfiles'
ln -sfn "$DOTFILES_DIR/fish" ~/.config/fish
ln -sfn "$DOTFILES_DIR/nvim" ~/.config/nvim
ln -sfn "$DOTFILES_DIR/.tmux.conf" ~/.tmux.conf
ln -sfn "$DOTFILES_DIR/.gitignore" ~/.gitignore
ln -sfn "$DOTFILES_DIR/.psqlrc" ~/.psqlrc

echo '> configuring git'
git config --global core.excludesFile ~/.gitignore
git config --global push.autoSetupRemote true
git config --global pull.rebase true
git config --global diff.tool nvimdiff
git config --global merge.tool nvimdiff
git config --global mergetool.keepBackup false

[ "${SHELL##*/}" = fish ] && { echo '* default shell is already fish'; exit 0; }
fish_path=$(command -v fish || true)
[ -n "$fish_path" ] || { echo '! fish not found in path' >&2; exit 1; }

echo '> changing default shell to fish'
grep -qxF "$fish_path" /etc/shells || echo "$fish_path" | sudo tee -a /etc/shells

chsh -s "$fish_path"
echo '* please log out and log back in for shell change to take effect'
# vim: ft=sh
