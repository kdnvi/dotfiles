#!/usr/bin/env bash
set -euo pipefail

link_dotfiles() {
    echo '> creating essential dirs'
    mkdir -p "${XDG_CONFIG_HOME:-~/.config}"
    mkdir -p ~/repos ~/personal

    echo '> linking dotfiles'
    ln -sfn $(pwd)/ghostty ~/.config/ghostty
    ln -sfn $(pwd)/fish ~/.config/fish
    ln -sfn $(pwd)/nvim ~/.config/nvim
    ln -sfn $(pwd)/.tmux.conf ~/.tmux.conf
    ln -sfn $(pwd)/.gitignore ~/.gitignore
    ln -sfn $(pwd)/.psqlrc ~/.psqlrc
}

setup_linux() {
    echo "> installing essential packages"
    sudo apt-get update && sudo apt-get install -y curl git tmux fish watch neovim tree ncdu ripgrep jq
    sudo snap install ghostty --classic
}

setup_macos() {
    xcode-select -p &>/dev/null || { echo '> installing command line tools for xcode'; xcode-select --install; }
    command -v brew &>/dev/null || {
        echo '> installing homebrew'
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
            eval "$(/opt/homebrew/bin/brew shellenv)"
    }
    echo '> installing essential packages'
    brew update && brew install git tmux fish watch neovim tree ncdu ripgrep jq ghostty font-ubuntu-sans-mono
}

config_git() {
    echo '> configuring git'
    git config --global core.excludesFile ~/.gitignore
    git config --global push.autoSetupRemote true
    git config --global pull.rebase true
    git config --global diff.tool nvimdiff
    git config --global merge.tool nvimdiff
    git config --global mergetool.keepBackup false
}

config_shell() {
    [[ $SHELL == */fish ]] && { echo '* default shell is already fish'; return 0; }
    local fish_path=$(command -v fish)
    [[ -n $fish_path ]] || { echo '! fish not found in path' >&2; return 1; }

    echo '> changing default shell to fish'
    grep -qxF "$fish_path" /etc/shells || echo "$fish_path" | sudo tee -a /etc/shells
    chsh -s "$fish_path"
    echo '* please log out and log back in for shell change to take effect'
}

main() {
    link_dotfiles
    case $(uname -s) in
        Linux)  setup_linux ;;
        Darwin) setup_macos ;;
        *)      echo '! unsupported os: only linux and macos' >&2; exit 1 ;;
    esac
    config_git
    config_shell
}

main "$@"
# vim: ft=bash
