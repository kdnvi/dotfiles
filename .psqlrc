\encoding unicode
\setenv PAGER 'less -XS'
\timing on
\conninfo
\x auto
\pset null 'NULL'
\pset linestyle unicode
\pset format wrapped
\set client_min_messages = warning;
\set PROMPT1 '%[%033[1;35m%]%n@%/%[%033[0m%]%R%x%# '
\set VERBOSITY verbose
\set HISTCONTROL ignoredups
\set HISTSIZE 10000
\set ON_ERROR_ROLLBACK interactive
\set AUTOCOMMIT off
\set uptime 'SELECT now() - pg_postmaster_start_time() AS uptime;'
\set sz 'SELECT schemaname, relname, pg_size_pretty(pg_total_relation_size(relid)) AS size FROM pg_stat_user_tables ORDER BY pg_total_relation_size(relid) DESC;'
\set ae 'EXPLAIN (ANALYZE, BUFFERS, VERBOSE, FORMAT TEXT)'
